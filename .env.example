# Twilio account settings
TWILIO_ACCOUNT_SID="your_account_sid"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_FROM_PHONE="+12345678901"
ALERT_TO_PHONE="+13155551234"

# WhatsApp sandbox settings
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
ALERT_TO_WHATSAPP="whatsapp:+13155551234"

# 30 seconds is a safer starting point on a cloud VM.
# If you still want the original behavior, change this to "1".
CHECK_INTERVAL_SECONDS="30"
